{
  "servers": {

    "mssql": {
      "command": "npx",
      "args": ["-y", "@connorbritain/mssql-mcp-server@latest"],
      "env": {
        "SERVER_NAME": "localhost",
        "DATABASE_NAME": "webshop_db",
        "SQL_AUTH_MODE": "sql",
        "SQL_USERNAME": "sa",
        "SQL_PASSWORD": "Demo1234!",
        "MSSQL_TRUST_SERVER_CERTIFICATE": "true"
      }
    },

    "git": {
      "command": "npx",
      "args": ["-y", "@cyanheads/git-mcp-server"],
      "env": {
        "GIT_DEFAULT_PATH": "${workspaceFolder}"
      }
    },

    "atlassian": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    }

  }
}